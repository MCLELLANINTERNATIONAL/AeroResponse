@page "/simulation"

<PageTitle>Simulation | AeroResponse</PageTitle>

<section class="scenario-page">
    <header class="scenario-header">
        <div>
            <span class="scenario-eyebrow">
                Training environment
            </span>

            <h1>Simulation</h1>

            <p>
                Launch and manage interactive aircraft emergency
                training sessions.
            </p>
        </div>
    </header>

    <div class="scenario-content-card page-placeholder-card">
        <h2>Simulation launcher coming soon</h2>

        <p>
            Use this page to select an aircraft, choose an emergency
            scenario, and begin a training run.
        </p>

        <a class="btn btn-primary"
           href="/scenarios">
            Choose a scenario
        </a>
    </div>
</section>