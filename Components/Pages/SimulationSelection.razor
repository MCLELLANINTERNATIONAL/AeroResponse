@page "/simulation/select"
@rendermode InteractiveServer

@using AeroResponse.Models
@using AeroResponse.Services
@using AeroResponse.Simulation
@using AeroResponse.Simulation.Layouts
@using SimulationSelectionModel = AeroResponse.Models.SimulationSelection

@inject ICockpitLayoutProvider LayoutProvider
@inject SimulationEngine SimulationEngine
@inject SimulationSelectionStorage SelectionStorage
@inject NavigationManager Navigation

<PageTitle>Select Simulation</PageTitle>

<main class="simulation-selection">

    <header class="selection-header">
        <p class="selection-eyebrow">
            AeroResponse Training Simulator
        </p>

        <h1>Select Your Training Session</h1>

        <p class="selection-description">
            Choose an available aircraft and emergency scenario
            before entering the cockpit.
        </p>
    </header>

    @if (!_isLoaded)
    {
        <section class="selection-message">
            Loading available aircraft and scenarios...
        </section>
    }
    else
    {
        @if (_savedSelection is not null)
        {
            <section class="resume-panel">

                <div>
                    <p class="panel-eyebrow">
                        Previous Selection
                    </p>

                    <h2>Resume Training</h2>

                    <p>
                        Aircraft:
                        <strong>
                            @GetAircraftName(_savedSelection.AircraftKey)
                        </strong>
                    </p>

                    <p>
                        Scenario:
                        <strong>
                            @GetScenarioName(_savedSelection.ScenarioType)
                        </strong>
                    </p>
                </div>

                <button type="button"
                        class="secondary-button"
                        @onclick="ResumeSavedSelection">
                    Resume
                </button>

            </section>
        }

        <section class="selection-grid">

            <article class="selection-panel">

                <p class="panel-eyebrow">
                    Step 1
                </p>

                <h2>Select Aircraft</h2>

                @if (_aircraftOptions.Count == 0)
                {
                    <p>No aircraft layouts are currently available.</p>
                }
                else
                {
                    <div class="option-list">

                        @foreach (var aircraft in _aircraftOptions)
                        {
                            var isSelected =
                                aircraft.Key == _selectedAircraftKey;

                            <button type="button"
                                    class="option-card @(isSelected ? "selected" : null)"
                                    @onclick="() => SelectAircraft(aircraft)">

                                <span class="option-title">
                                    @aircraft.Name
                                </span>

                                <span class="option-detail">
                                     | 
                                    @aircraft.EngineCount
                                    @(aircraft.EngineCount == 1
                                        ? " engine"
                                        : " engines")
                                     | 
                                </span>

                                <span class="option-detail">
                                    @aircraft.Instruments.Count total instruments.
                                </span>

                            </button>
                        }

                    </div>
                }

            </article>

            <article class="selection-panel">

                <p class="panel-eyebrow">
                    Step 2
                </p>

                <h2>Select Scenario</h2>

                @if (_scenarioOptions.Count == 0)
                {
                    <p>No simulation scenarios are currently available.</p>
                }
                else
                {
                    <div class="option-list">

                        @foreach (var scenario in _scenarioOptions)
                        {
                            var isSelected =
                                scenario.ScenarioType ==
                                _selectedScenarioType;

                            <button type="button"
                                    class="option-card @(isSelected ? "selected" : null)"
                                    @onclick="() => SelectScenario(scenario)">

                                <span class="option-title">
                                    @scenario.ScenarioType
                                </span>

                                <span class="option-detail">
                                    Emergency procedure training
                                </span>

                            </button>
                        }

                    </div>
                }

            </article>

        </section>

        <section class="briefing-panel">

            <article class="briefing-section">

                <p class="panel-eyebrow">
                    Aircraft Briefing
                </p>

                @if (SelectedAircraft is null)
                {
                    <p>Select an aircraft to view its configuration.</p>
                }
                else
                {
                    <h2>@SelectedAircraft.Name</h2>

                    <dl class="aircraft-details">

                        <div>
                            <dt>Aircraft ID</dt>
                            <dd>@SelectedAircraft.AircraftId</dd>
                        </div>

                        <div>
                            <dt>Layout Key</dt>
                            <dd>@SelectedAircraft.Key</dd>
                        </div>

                        <div>
                            <dt>Engines</dt>
                            <dd>@SelectedAircraft.EngineCount</dd>
                        </div>

                        <div>
                            <dt>Panel</dt>
                            <dd>
                                @SelectedAircraft.Columns ×
                                @SelectedAircraft.Rows
                            </dd>
                        </div>

                        <div>
                            <dt>Instruments</dt>
                            <dd>@SelectedAircraft.Instruments.Count</dd>
                        </div>

                    </dl>
                }

            </article>

            <article class="briefing-section">

                <p class="panel-eyebrow">
                    Scenario Briefing
                </p>

                @if (SelectedScenario is null)
                {
                    <p>Select a scenario to view its briefing.</p>
                }
                else
                {
                    <h2>@SelectedScenario.ScenarioType</h2>

                    <p>
                        This scenario will initialize the aircraft state,
                        emergency conditions, procedure checklist, and
                        scoring rules.
                    </p>

                    @if (SelectedAircraft is not null)
                    {
                        var previewSteps =
                            SelectedScenario.GetProcedureSteps(
                                SelectedAircraft,
                                scenarioId: 0);

                        <h3>Training Objectives</h3>

                        <ol class="procedure-preview">
                            @foreach (var step in previewSteps)
                            {
                                <li>
                                    @step.Instruction

                                    @if (step.IsSafetyCritical)
                                    {
                                        <strong class="critical-label">
                                            Safety Critical
                                        </strong>
                                    }
                                </li>
                            }
                        </ol>
                    }
                }

            </article>

        </section>

        @if (!string.IsNullOrWhiteSpace(_validationMessage))
        {
            <div class="validation-message"
                 role="alert">
                @_validationMessage
            </div>
        }

        <footer class="selection-actions">

            <button type="button"
                    class="text-button"
                    @onclick="ReturnHome">
                Return Home
            </button>

            <button type="button"
                    class="primary-button"
                    disabled="@(!CanStart || _isStarting)"
                    @onclick="StartSimulationAsync">

                @(_isStarting
                    ? "Preparing Simulation..."
                    : "Begin Simulation")

            </button>

        </footer>
    }

</main>

@code {
    private IReadOnlyList<CockpitLayoutDefinition> _aircraftOptions =
        [];

    private IReadOnlyList<ISimulationScenario> _scenarioOptions =
        [];

    private SimulationSelectionModel? _savedSelection;

    private string? _selectedAircraftKey;
    private string? _selectedScenarioType;

    private string? _validationMessage;

    private bool _isLoaded;
    private bool _isStarting;

    private CockpitLayoutDefinition? SelectedAircraft =>
        _aircraftOptions.FirstOrDefault(
            aircraft =>
                aircraft.Key == _selectedAircraftKey);

    private ISimulationScenario? SelectedScenario =>
        _scenarioOptions.FirstOrDefault(
            scenario =>
                scenario.ScenarioType ==
                _selectedScenarioType);

    private bool CanStart =>
        SelectedAircraft is not null &&
        SelectedScenario is not null;

    protected override async Task OnAfterRenderAsync(
        bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _aircraftOptions =
            LayoutProvider.GetLayouts();

        _scenarioOptions =
            SimulationEngine.GetScenarios();

        _savedSelection =
            await SelectionStorage.GetAsync();

        if (_savedSelection?.IsValid == true)
        {
            var savedAircraftExists =
                _aircraftOptions.Any(
                    aircraft =>
                        aircraft.Key ==
                        _savedSelection.AircraftKey);

            var savedScenarioExists =
                _scenarioOptions.Any(
                    scenario =>
                        scenario.ScenarioType ==
                        _savedSelection.ScenarioType);

            if (savedAircraftExists &&
                savedScenarioExists)
            {
                _selectedAircraftKey =
                    _savedSelection.AircraftKey;

                _selectedScenarioType =
                    _savedSelection.ScenarioType;
            }
            else
            {
                await SelectionStorage.ClearAsync();
                _savedSelection = null;
            }
        }

        _isLoaded = true;

        await InvokeAsync(StateHasChanged);
    }

    private void SelectAircraft(
        CockpitLayoutDefinition aircraft)
    {
        _selectedAircraftKey = aircraft.Key;
        _validationMessage = null;
    }

    private void SelectScenario(
        ISimulationScenario scenario)
    {
        _selectedScenarioType =
            scenario.ScenarioType;

        _validationMessage = null;
    }

    private async Task StartSimulationAsync()
    {
        if (_isStarting)
        {
            return;
        }

        if (SelectedAircraft is null ||
            SelectedScenario is null)
        {
            _validationMessage =
                "Select both an aircraft and a scenario.";

            return;
        }

        _isStarting = true;
        _validationMessage = null;

        try
        {
            var selection = new SimulationSelectionModel
            {
                AircraftKey = SelectedAircraft.Key,
                ScenarioType = SelectedScenario.ScenarioType
            };

            await SelectionStorage.SaveAsync(selection);

            NavigateToSimulation(selection);
        }
        catch
        {
            _validationMessage =
                "The simulation could not be prepared.";

            _isStarting = false;
        }
    }

    private void NavigateToSimulation(
        SimulationSelectionModel selection)
    {
        // The route is /simulation/{aircraftId}/{simulationType}, but this
        // model only tracks AircraftKey — there's no separate AircraftId
        // to route on. So AircraftKey fills the {aircraftId} route segment.
        // The receiving page's route parameter name doesn't need to match
        // this property name; it just needs a value that identifies the
        // aircraft, and Key is the only one this model has.
        var aircraftKey =
            Uri.EscapeDataString(
                selection.AircraftKey);

        var scenarioType =
            Uri.EscapeDataString(
                selection.ScenarioType);

        Navigation.NavigateTo(
            $"/simulation/{aircraftKey}/{scenarioType}");
    }

    private void ResumeSavedSelection()
    {
        if (_savedSelection?.IsValid != true)
        {
            return;
        }

        NavigateToSimulation(_savedSelection);
    }

    private void ReturnHome()
    {
        Navigation.NavigateTo("/");
    }

    private string GetAircraftName(string aircraftKey)
    {
        return _aircraftOptions
                   .FirstOrDefault(
                       aircraft =>
                           aircraft.Key == aircraftKey)
                   ?.Name
               ?? aircraftKey;
    }

    private string GetScenarioName(string scenarioType)
    {
        return _scenarioOptions
                   .FirstOrDefault(
                       scenario =>
                           scenario.ScenarioType ==
                           scenarioType)
                   ?.ScenarioType
               ?? scenarioType;
    }
}